#!/usr/bin/env bash
# Displays DNS information for subdomains

domain=$1
subdomain=$2

display_record() {
    local sub=$1
    local line

    line=$(dig "$sub.$domain" +short | awk 'NR==1')

    echo "The subdomain $sub is a A record and points to $line"
}

if [ -z "$subdomain" ]; then
    display_record "www"
    display_record "lb-01"
    display_record "web-01"
    display_record "web-02"
else
    display_record "$subdomain"
fi