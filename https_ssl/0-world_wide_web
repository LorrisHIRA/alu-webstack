#!/usr/bin/env bash
# Displays DNS information for subdomains

domain=$1
subdomain=$2

display_record() {
    local sub=$1
    local line

    line=$(dig "$sub.$domain" | awk '/ANSWER SECTION:/ {getline; print}')

    record_type=$(echo "$line" | awk '{print $4}')
    destination=$(echo "$line" | awk '{print $5}')

    echo "The subdomain $sub is a $record_type record and points to $destination"
}

if [ -z "$subdomain" ]; then
    display_record "www"
    display_record "lb-01"
    display_record "web-01"
    display_record "web-02"
else
    display_record "$subdomain"
fi