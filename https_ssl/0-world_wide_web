#!/usr/bin/env bash
# This script audits subdomains of lorris.tech and displays their DNS record type and IP

# Function to get subdomain information
get_subdomain_info() {
    local domain=$1
    local sub=$2

    # Run dig and extract ANSWER SECTION
    info=$(dig ${sub}.${domain} | awk '/ANSWER SECTION:/ {getline; print $1 " " $4 " " $5}')

    # Parse the information
    sub_name=$(echo $info | awk '{print $1}' | sed 's/\.$//')  # Remove trailing dot
    record_type=$(echo $info | awk '{print $2}')               # Record type (A)
    ip=$(echo $info | awk '{print $3}')                        # IP address

    echo "The subdomain ${sub} is a ${record_type} record and points to ${ip}"
}

# Get arguments
domain=$1
subdomain=$2

# If no subdomain is provided, check default ones
if [ -z "$subdomain" ]; then
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info $domain $sub
    done
else
    # If subdomain is provided, check only that
    get_subdomain_info $domain $subdomain
fi
